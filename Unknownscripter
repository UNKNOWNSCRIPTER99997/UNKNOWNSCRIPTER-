local function ToggleESP()
    espState = not espState
    settings.espEnabled = espState
    
    if espState then
        espBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
        espBtn.BorderColor3 = Color3.fromRGB(0, 255, 0)
        espBtn.Text = "ON"
        espIndicator.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
        PlayActivationSound()
        UpdateESP()
    else
        espBtn.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
        espBtn.BorderColor3 = Color3.fromRGB(255, 0, 0)
        espBtn.Text = "OFF"
        espIndicator.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
        PlayHackerSound()
        for player, _ in pairs(espObjects) do
            RemoveESP(player)
        end
    end
end

